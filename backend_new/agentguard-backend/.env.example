# ─── LLM ─────────────────────────────────────────────────────────────────────
# Provider: Groq (OpenAI-compatible) or OpenAI directly
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=qwen/qwen3-32b

# ─── Blockchain ───────────────────────────────────────────────────────────────
# Arbitrum Sepolia RPC (Alchemy, Infura, or public)
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
# Private key of the wallet that will sign credential submissions
AGENT_SIGNER_PRIVATE_KEY=0xdeadbeef...your_private_key_here
# Deployed AgentGuard contract address
AGENTGUARD_CONTRACT_ADDRESS=0xYourContractAddressHere

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
