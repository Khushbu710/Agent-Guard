# ─────────────────────────────────────────────────────────────────────────────
# AgentGuard — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────


# ── Deployer Wallet ───────────────────────────────────────────────────────────
# Private key of the wallet that will deploy AgentGuard and act as protocol
# owner. Must have Arbitrum Sepolia ETH for gas.
#
# Get testnet ETH from:
#   https://faucet.triangleplatform.com/arbitrum/sepolia
#   https://www.alchemy.com/faucets/arbitrum-sepolia
#
# Format: hex string WITHOUT leading 0x
DEPLOYER_PRIVATE_KEY=your_private_key_here_without_0x_prefix


# ── RPC Endpoint ─────────────────────────────────────────────────────────────
# Arbitrum Sepolia JSON-RPC URL.
# The public endpoint below works but may be rate-limited under heavy use.
# For production use, provision a dedicated endpoint via Alchemy or Infura.
#
# Public (rate-limited):
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
#
# Alchemy example (replace with your key):
# ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
#
# Infura example (replace with your key):
# ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia.infura.io/v3/YOUR_INFURA_KEY


# ── Contract Verification ─────────────────────────────────────────────────────
# Arbiscan API key for source code verification after deployment.
# Register and obtain a key at: https://arbiscan.io/register
# Then generate an API key at:  https://arbiscan.io/myapikey
ARBISCAN_API_KEY=your_arbiscan_api_key_here


# ── Optional: Gas Reporter ────────────────────────────────────────────────────
# Set to "true" to enable gas cost reporting during `npx hardhat test`.
# Outputs a table of function gas costs alongside test results.
REPORT_GAS=false


# ── Optional: CoinMarketCap (for gas reporter USD pricing) ───────────────────
# Provides live ETH/USD price to gas reporter for cost estimates in USD.
# Obtain a free key at: https://pro.coinmarketcap.com/signup
# COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here